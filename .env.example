# =============================================================================
# NMSL Portal - Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development
# For production (Render/Azure), set these in your hosting platform's UI
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API URL - CHANGE THIS FOR EACH ENVIRONMENT
# Local development: http://localhost:4000
# Render: https://your-app-name.onrender.com
# Azure: https://your-app-name.azurewebsites.net
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Enable mock data (set to "false" to use real API)
# Development: "true" (uses mock data)
# Production: "false" (uses real backend)
NEXT_PUBLIC_USE_MOCKS=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable experimental features
NEXT_PUBLIC_ENABLE_PREMIUM_THEME_TOGGLE=false
NEXT_PUBLIC_ENABLE_ROLE_SWITCHER=false

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Application name and branding
NEXT_PUBLIC_APP_NAME=NMSL Portal
NEXT_PUBLIC_APP_VERSION=1.0.0

# Default location for the app
NEXT_PUBLIC_DEFAULT_LOCATION=Abuja

# -----------------------------------------------------------------------------
# Deployment Platform (for debugging)
# -----------------------------------------------------------------------------
# Set to: "local" | "render" | "azure" | "vercel"
NEXT_PUBLIC_PLATFORM=local

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring (for future use)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# IMPORTANT NOTES:
# -----------------------------------------------------------------------------
# 1. Variables starting with NEXT_PUBLIC_ are exposed to the browser
# 2. Never put secrets in NEXT_PUBLIC_ variables
# 3. For production, set these in your hosting platform's environment UI
# 4. Copy this file to .env.local and customize for local development
# =============================================================================
