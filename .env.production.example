# =============================================================================
# NMSL Portal - Production Environment Template
# =============================================================================
# Use this as reference when setting environment variables in:
# - Render Dashboard → Environment tab
# - Azure Portal → Configuration → Application settings
# - Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL: Backend API URL
# -----------------------------------------------------------------------------
# ***CHANGE THIS TO YOUR ACTUAL BACKEND URL***
# 
# Render example:     https://nmsl-api.onrender.com
# Azure example:      https://nmsl-api.azurewebsites.net
# Custom domain:      https://api.nmsl.com
#
NEXT_PUBLIC_API_BASE_URL=https://YOUR-BACKEND-URL-HERE

# -----------------------------------------------------------------------------
# Mock Data - MUST BE FALSE IN PRODUCTION
# -----------------------------------------------------------------------------
# Set to "false" to use real backend API
NEXT_PUBLIC_USE_MOCKS=false

# -----------------------------------------------------------------------------
# Platform Identifier
# -----------------------------------------------------------------------------
# Set to: "render" | "azure" | "vercel" | "production"
# This helps with debugging and monitoring
NEXT_PUBLIC_PLATFORM=render

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=NMSL Portal
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_DEFAULT_LOCATION=Abuja

# -----------------------------------------------------------------------------
# Feature Flags - Production Defaults
# -----------------------------------------------------------------------------
# Keep these false unless specifically needed
NEXT_PUBLIC_ENABLE_PREMIUM_THEME_TOGGLE=false
NEXT_PUBLIC_ENABLE_ROLE_SWITCHER=false

# -----------------------------------------------------------------------------
# Optional: Future Analytics/Monitoring
# -----------------------------------------------------------------------------
# Uncomment and add values when ready
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================================
# DEPLOYMENT INSTRUCTIONS:
# =============================================================================
# 
# FOR RENDER:
# 1. Go to dashboard.render.com → Your service → Environment
# 2. Add each variable above (key = value)
# 3. Click "Save" (triggers auto-redeploy)
#
# FOR AZURE:
# 1. Go to portal.azure.com → Your Static Web App → Configuration
# 2. Click "Application settings" → "Add"
# 3. Enter each variable (Name = Value)
# 4. Click "Save" (triggers auto-restart)
#
# FOR VERCEL:
# 1. Go to vercel.com → Your project → Settings → Environment Variables
# 2. Add each variable for Production environment
# 3. Redeploy from Deployments tab
#
# =============================================================================
# VALIDATION CHECKLIST BEFORE GOING LIVE:
# =============================================================================
# [ ] NEXT_PUBLIC_API_BASE_URL points to real deployed backend
# [ ] NEXT_PUBLIC_USE_MOCKS is set to "false"
# [ ] Backend CORS allows your frontend domain
# [ ] Backend is deployed and accessible
# [ ] Test login works
# [ ] Test appointment creation/update works
# [ ] Test appointment locking works
# [ ] Verify audit logs are being recorded
# =============================================================================
